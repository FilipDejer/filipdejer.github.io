{% extends 'base.html.twig' %}

{% block title %}Szczegóły książki{% endblock %}

{% block body %}
    <div class="container">
        <h1 class="mb-4">Podgląd: {{ book.title }}</h1>

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <table class="table table-borderless">
                    <tbody>
                    <tr>
                        <th style="width: 150px;">Id</th>
                        <td>{{ book.id }}</td>
                    </tr>
                    <tr>
                        <th>Title</th>
                        <td>{{ book.title }}</td>
                    </tr>
                    <tr>
                        <th>Pages</th>
                        <td>{{ book.pages }}</td>
                    </tr>
                    <tr>
                        <th>Description</th>
                        <td>{{ book.description }}</td>
                    </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-flex gap-2">
            <a href="{{ path('app_book_index') }}" class="btn btn-secondary">Powrót</a>
            <a href="{{ path('app_book_edit', {'id': book.id}) }}" class="btn btn-warning">Edytuj</a>
            {{ include('book/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
