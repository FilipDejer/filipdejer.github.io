{% extends 'base.html.twig' %}

{% block title %}Lista Książek{% endblock %}

{% block body %}
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Lista Książek</h1>
            <a href="{{ path('app_book_new') }}" class="btn btn-success">Dodaj nową</a>
        </div>

        <div class="table-responsive shadow-sm bg-white p-3 rounded">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Title</th>
                    <th>Pages</th>
                    <th>Description</th>
                    <th>Akcje</th>
                </tr>
                </thead>
                <tbody>
                {% for book in books %}
                    <tr>
                        <td>{{ book.id }}</td>
                        <td class="fw-bold">{{ book.title }}</td>
                        <td>{{ book.pages }}</td>
                        <td>{{ book.description }}</td>
                        <td>
                            <a href="{{ path('app_book_show', {'id': book.id}) }}" class="btn btn-sm btn-info text-white">Pokaż</a>
                            <a href="{{ path('app_book_edit', {'id': book.id}) }}" class="btn btn-sm btn-warning">Edytuj</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Brak wpisów w bazie danych.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
