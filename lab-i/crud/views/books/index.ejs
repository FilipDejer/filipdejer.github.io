<%- include('../partials/header') %>

<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 text-dark">Lista Książek</h1>
    <a href="/books/create" class="btn btn-success shadow-sm">Dodaj nową książkę</a>
  </div>

  <div class="table-responsive shadow-sm bg-white p-3 rounded">
    <table class="table table-striped table-hover align-middle mb-0">
      <thead class="table-dark">
        <tr>
          <th style="width: 80px;">ID</th>
          <th>Tytuł</th>
          <th style="width: 150px;">Liczba stron</th>
          <th style="width: 200px;" class="text-center">Akcje</th>
        </tr>
      </thead>
      <tbody>
        <% books.forEach(function(book) { %>
          <tr>
            <td><%= book.id %></td>
            <td class="fw-bold text-secondary"><%= book.title %></td>
            <td><span class="badge bg-secondary p-2"><%= book.pages %> str.</span></td>
            <td class="text-center">
              <a href="/books/<%= book.id %>" class="btn btn-sm btn-info text-white me-1">Szczegóły</a>
              <a href="/books/<%= book.id %>/edit" class="btn btn-sm btn-warning">Edytuj</a>
            </td>
          </tr>
        <% }); %>
        <% if (books.length === 0) { %>
          <tr>
            <td colspan="4" class="text-center text-muted py-4">Brak pozycji w bazie danych.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>